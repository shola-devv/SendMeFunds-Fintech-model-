{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "typeRoots": ["./node_modules/@types"]  // typeRoots is for folders, not individual files
  },
  "include": ["**/*.ts", "**/*.d.ts"],  // ← make sure .d.ts files are globbed
  "exclude": ["node_modules", "dist"]
}